# ===========================
# PostgreSQL
# ===========================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=giaptech_ipages
POSTGRES_USER=giaptech
POSTGRES_PASSWORD=GiapTech@2024!

# ===========================
# Redis
# ===========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=Redis@2024!

# ===========================
# JWT
# ===========================
JWT_SECRET=GiapTechIpagesJwtSecret2024SuperLongSecretKeyForHS256Algorithm!
JWT_ISSUER=GiapTech.Ipages
JWT_AUDIENCE=GiapTech.Ipages.Clients
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# ===========================
# MinIO (S3-compatible storage)
# ===========================
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=MinIO@2024!
MINIO_BUCKET_NAME=ipages-storage

# ===========================
# Traefik
# ===========================
TRAEFIK_DASHBOARD_PORT=8080

# ===========================
# Backend API
# ===========================
API_PORT=5000
ASPNETCORE_ENVIRONMENT=Production

# ===========================
# Frontend Ports (for override)
# ===========================
FRONTEND_HOST_PORT=3000
FRONTEND_TENANT_PORT=3001
FRONTEND_CLIENT_PORT=3002

# ===========================
# Domain (for production)
# ===========================
BASE_DOMAIN=localhost
